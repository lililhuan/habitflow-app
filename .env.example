# HabitFlow Environment Configuration
# Copy this file to .env and update with your values

# ======================
# Security Settings
# ======================

# Maximum failed login attempts before account lockout
MAX_FAILED_ATTEMPTS=5

# Account lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15

# Session timeout in minutes (auto logout after inactivity)
SESSION_TIMEOUT_MINUTES=30

# ======================
# Admin Configuration
# ======================

# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@habitflow.com,admin@gmail.com

# ======================
# Database Configuration
# ======================

# Database file name (stored in habitflow folder) — local only
DATABASE_NAME=habitflow.db

# Full path override — use this on cloud (e.g., /tmp/habitflow.db on Render/Heroku)
# DATABASE_PATH=/tmp/habitflow.db

# ======================
# Web / Deployment Settings
# ======================

# Set to 1 to run as a web app (browser UI instead of desktop window)
# Automatically set to 1 on Heroku/Render/Railway via PORT detection
# FLET_WEB=1

# Port to listen on (set automatically by Heroku/Render/Railway)
# PORT=8080

# ======================
# OAuth Configuration
# ======================

# Google OAuth 2.0 (https://console.cloud.google.com/apis/credentials)
# Set Authorized redirect URI to: http://localhost:8765/oauth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth App (https://github.com/settings/developers)
# Set Authorization callback URL to: http://localhost:8765/oauth/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ======================
# Application Settings
# ======================

# Default theme: Default, Ocean Blue, Forest Green, Sunset Orange, 
#                Purple Dream, Rose Gold, Midnight Black, Sky Blue
DEFAULT_THEME=Default

# Enable debug mode (True/False)
DEBUG_MODE=False
